PORT=3000
# Set SERVE_FRONTEND=true when Express should also serve the React build (e.g. local dev
# or cPanel). On Vercel, the CDN serves the React build and only /api/* hits Express –
# leave this unset.
SERVE_FRONTEND=

# Extra CORS origins to allow (comma-separated, full origin including scheme).
# The production domains are allowed by default; add any additional origins here.
# Example: CORS_ORIGIN=https://staging.example.com
CORS_ORIGIN=
ADMIN_PASSWORD=change-me
JWT_SECRET=change-this-jwt-secret-use-a-long-random-string
NODE_ENV=development

# MongoDB Atlas – required for all database operations (posts, gallery, user auth).
# Get your connection string from: Atlas Console → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority
# Optional direct-node fallback used when SRV DNS lookups are blocked in your host environment.
# Example:
# MONGODB_URI_DIRECT=mongodb://USERNAME:PASSWORD@ac-xxxx-shard-00-00.xxx.mongodb.net:27017,ac-xxxx-shard-00-01.xxx.mongodb.net:27017,ac-xxxx-shard-00-02.xxx.mongodb.net:27017/DBNAME?ssl=true&replicaSet=atlas-xxxxx-shard-0&authSource=admin&retryWrites=true&w=majority
MONGODB_URI_DIRECT=
