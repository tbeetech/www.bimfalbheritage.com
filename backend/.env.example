PORT=5000
ADMIN_PASSWORD=change-me
SESSION_SECRET=super-secret
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas – required for database storage
# Create a free cluster at https://www.mongodb.com/cloud/atlas, then get the connection string from:
# Atlas Console → Database → Connect → Drivers → Copy the connection string
# Replace <username>, <password>, and <dbname> with your credentials.
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# Firebase – required for image uploads to Firebase Storage (optional)
# Paste the full JSON content of your Firebase service account key as a single line.
# Download it from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# If not set, uploaded images will be served from local disk instead.
FIREBASE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# Your Firebase Storage bucket name (found in Firebase Console → Storage → Files tab)
# For the bimfalb-heritage project use one of:
#   bimfalb-heritage.firebasestorage.app   (default for newer projects)
#   bimfalb-heritage.appspot.com           (legacy format)
FIREBASE_STORAGE_BUCKET=bimfalb-heritage.firebasestorage.app
