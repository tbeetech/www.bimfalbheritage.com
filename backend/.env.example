PORT=3000
# Set SERVE_FRONTEND=true when Express should also serve the React build (e.g. on Render).
# On cPanel, Apache serves public_html/ directly – leave this unset.
SERVE_FRONTEND=
ADMIN_PASSWORD=change-me
JWT_SECRET=change-this-jwt-secret
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173,https://www-bimfalbheritage-com.onrender.com

# MongoDB Atlas – required for database storage
# Get your connection string from: Atlas Console → Database → Connect → Drivers
# Replace <username>, <password>, and <cluster> with your Atlas database credentials and cluster hostname.
