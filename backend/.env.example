PORT=3000
# Set SERVE_FRONTEND=true when Express should also serve the React build (e.g. on Render).
# On cPanel, Apache serves ~/public_html/ directly and only /api/* reaches Node.js – leave this unset.
SERVE_FRONTEND=
ADMIN_PASSWORD=change-me
JWT_SECRET=change-this-jwt-secret-use-a-long-random-string
NODE_ENV=development

# Comma-separated list of allowed CORS origins.
# Leave empty to allow all origins (development default).
# In production set to your exact frontend URL(s):
#   CORS_ORIGIN=https://www.bimfalbheritage.org,https://bimfalbheritage.org,https://www.bimfalbheritage.com,https://bimfalbheritage.com
CORS_ORIGIN=http://localhost:5173

# MongoDB Atlas – required for all database operations (posts, gallery, user auth).
# Get your connection string from: Atlas Console → Database → Connect → Drivers
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/DBNAME?retryWrites=true&w=majority
