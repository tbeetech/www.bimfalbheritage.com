# Leave empty when the backend API is on the same domain (Vercel or cPanel setup).
# The Vite dev server proxy forwards /api/* to http://localhost:3000 automatically.
# Set to a full origin only when testing against a separate standalone backend:
#   VITE_API_URL=http://localhost:3000
VITE_API_URL=

# Optional production fallback used when VITE_API_URL is empty and the browser
# hostname matches VITE_PROD_HOSTNAMES. Leave empty when using same-origin
# API routing (e.g. Vercel routes /api/* to the serverless function).
VITE_PROD_API_FALLBACK_ORIGIN=
VITE_PROD_HOSTNAMES=www.bimfalbheritage.org,bimfalbheritage.org,www.bimfalbheritage.com,bimfalbheritage.com
