# Leave empty when the backend API is on the same domain (e.g. cPanel with
# the Node.js app serving /api/*, or Render with SERVE_FRONTEND=true).
# Set to the full backend origin only when the API is on a separate host:
#   VITE_API_URL=https://api.bimfalbheritage.com
#
# For local development the Vite dev server proxy (vite.config.js server.proxy)
# forwards /api/* to http://localhost:3000 automatically – no need to set this.
VITE_API_URL=
