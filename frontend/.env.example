# Leave empty when the backend API is on the same domain (cPanel setup).
# Set to the full backend origin when frontend/backend are split (e.g. Vercel -> Render):
#   VITE_API_URL=https://bimfalb-heritage.onrender.com
# Local dev note: Vite dev server proxy forwards /api/* to http://localhost:3000.
VITE_API_URL=

# Optional production fallback used when VITE_API_URL is empty and the browser
# hostname matches VITE_PROD_HOSTNAMES.
VITE_PROD_API_FALLBACK_ORIGIN=https://bimfalb-heritage.onrender.com
VITE_PROD_HOSTNAMES=www.bimfalbheritage.org,bimfalbheritage.org,www.bimfalbheritage.com,bimfalbheritage.com
